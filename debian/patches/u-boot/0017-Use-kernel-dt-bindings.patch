From c4bc35208fa54368260ff06fe98e202837b7723f Mon Sep 17 00:00:00 2001
From: Nick Alilovic <nickalilovic@gmail.com>
Date: Fri, 13 Mar 2026 12:05:57 -0400
Subject: [PATCH] Use kernel dt-bindings

Use kernel dt-bindings
---
 arch/arm/dts/sun60i-a733.dtsi                 |  33 +-
 drivers/clk/sunxi/clk_a733.c 		       |   2 --
 drivers/clk/sunxi/clk_a733_r.c                |   2 -
 include/dt-bindings/clock/sun60i-a733-ccu.h   | 463 +++++++++++-------
 include/dt-bindings/clock/sun60i-a733-r-ccu.h |  29 +-
 include/dt-bindings/reset/sun60i-a733-ccu.h   | 196 +++++---
 include/dt-bindings/reset/sun60i-a733-r-ccu.h |  29 +-
 7 files changed, 458 insertions(+), 296 deletions(-)

Index: u-boot-dlan17/src/arch/arm/dts/sun60i-a733.dtsi
===================================================================
--- u-boot-dlan17.orig/src/arch/arm/dts/sun60i-a733.dtsi
+++ u-boot-dlan17/src/arch/arm/dts/sun60i-a733.dtsi
@@ -281,17 +281,6 @@
 			status = "disabled";
 		};
 
-		uart7: serial@2501c00 {
-			compatible = "snps,dw-apb-uart";
-			reg = <0x02501c00 0x400>;
-			interrupts = <GIC_SPI 9 IRQ_TYPE_LEVEL_HIGH>;
-			reg-shift = <2>;
-			reg-io-width = <4>;
-			clocks = <&ccu CLK_BUS_UART7>;
-			resets = <&ccu RST_BUS_UART7>;
-			status = "disabled";
-		};
-
 		gic: interrupt-controller@3400000 {
 			compatible = "arm,gic-v3";
 			#address-cells = <1>;
Index: u-boot-dlan17/src//drivers/clk/sunxi/clk_a733.c b/drivers/clk/sunxi/clk_a733.c
===================================================================
--- u-boot-dlan17.orig/src/drivers/clk/sunxi/clk_a733.c
+++ u-boot-dlan17/src/drivers/clk/sunxi/clk_a733.c
@@ -38,8 +38,6 @@ static struct ccu_clk_gate a733_gates[] = {
 	[CLK_BUS_OHCI1]		= GATE(0x130c, BIT(0)),
 	[CLK_BUS_EHCI0]		= GATE(0x1304, BIT(4)),
 	[CLK_BUS_EHCI1]		= GATE(0x130c, BIT(4)),
-	[CLK_USB_GATE0]		= GATE(0x1304, BIT(8)),
-	[CLK_USB_GATE1]		= GATE(0x130c, BIT(8)),
 };
 
 static struct ccu_reset a733_resets[] = {
